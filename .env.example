# ============================================================
#  AdilaNet — Environment Variables
#  Salin file ini ke .env dan isi nilainya
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database PostgreSQL ──────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://adilanet:adilanet_pass_2024@localhost:5432/adilanet

# ── URL Publik Aplikasi ──────────────────────────────────────
# Dipakai untuk callback webhook QRIS / payment
APP_URL=http://IP_SERVER_KAMU:5000

# ── Payment Gateway Sanpay (opsional) ────────────────────────
# Daftar di https://sanpay.site
SANPAY_API_KEY=
SANPAY_MERCHANT_ID=

# ── Gemini AI (opsional) ─────────────────────────────────────
GEMINI_API_KEY=
