# ============================================================
#  AdilaNet — Environment Variables
#  Salin file ini ke .env dan isi nilainya
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database PostgreSQL ──────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://adilanet:adilanet_pass_2024@localhost:5432/adilanet

# ── Keamanan Sesi (WAJIB) ────────────────────────────────────
# String acak panjang untuk menandatangani cookie sesi.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── URL Publik Aplikasi ──────────────────────────────────────
# Dipakai untuk callback webhook QRIS / payment
APP_URL=http://IP_SERVER_KAMU:5000

# ── Secure Cookie (HTTPS) ────────────────────────────────────
# Biarkan kosong/false kalau akses lewat HTTP (mis. IP LAN) — kalau diisi
# "true" tapi server masih HTTP, login akan auto-logout terus.
# Set "true" HANYA jika app dilayani lewat HTTPS (domain + TLS / reverse proxy).
COOKIE_SECURE=false

# ── Payment Gateway Sanpay (opsional) ────────────────────────
# Daftar di https://sanpay.site
SANPAY_API_KEY=
SANPAY_MERCHANT_ID=
# Secret untuk verifikasi webhook Sanpay (opsional tapi disarankan).
# Jika diisi, webhook wajib mengirim header x-webhook-secret yang cocok.
SANPAY_WEBHOOK_SECRET=

# ── Gemini AI (opsional) ─────────────────────────────────────
GEMINI_API_KEY=
